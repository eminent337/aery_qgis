"""Tests for RPCBridge."""

import json
import os
from unittest.mock import MagicMock, patch, PropertyMock

import pytest
from aery_plugin.rpc_bridge import RPCBridge, _find_aery_binary


@pytest.fixture
def bridge():
    """Create an RPCBridge with mocked subprocess and empty config."""
    with (
        patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen,
        patch("aery_plugin.rpc_bridge.os.path.exists", return_value=False),  # No config file
        patch("aery_plugin.rpc_bridge.print"),  # Suppress stderr noise
    ):
        # Mock process with stdin/stdout
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        # stdout.readline returns empty (no messages)
        mock_process.stdout.readline.return_value = "\n"
        mock_process.stderr.readline.return_value = "\n"
        mock_popen.return_value = mock_process

        b = RPCBridge(cwd="/tmp", port=9999)
        yield b
        b.shutdown()


def test_find_aery_binary_bundled():
    """_find_aery_binary returns the bundled binary path when it exists."""
    binary = _find_aery_binary()
    assert "aery-qgis-runner" in binary
    assert os.path.isfile(binary), f"Binary not found at: {binary}"


def test_find_aery_binary_fallback():
    """When bundled binary doesn't exist, falls back to 'aery'."""
    with patch("aery_plugin.rpc_bridge.os.path.isfile", return_value=False):
        with patch("aery_plugin.rpc_bridge.os.access", return_value=False):
            assert _find_aery_binary() == "aery"


def test_spawn_bundled_binary(bridge):
    """spawn() launches bundled QGIS runner with port-first contract."""
    with (
        patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen,
        patch("aery_plugin.rpc_bridge._find_aery_binary", return_value="/mock/bin/aery-qgis-runner"),
        patch("aery_plugin.rpc_bridge.os.path.exists", return_value=False),
    ):
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = None
        mock_popen.return_value = mock_process

        bridge.spawn()

        mock_popen.assert_called_once()
        args = mock_popen.call_args[0][0]
        assert args[0] == "/mock/bin/aery-qgis-runner"
        assert args[1] == "9999"
        assert "--mode" not in args
        assert "--model" not in args


def test_spawn_no_provider_file_uses_agent_dir(bridge, tmp_path):
    """spawn() does NOT pass --provider-file; config comes from agent dir env var."""
    with (
        patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen,
        patch("aery_plugin.rpc_bridge._find_aery_binary", return_value="/mock/bin/aery-qgis-runner"),
    ):
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = None
        mock_popen.return_value = mock_process

        bridge.spawn()

        args = mock_popen.call_args[0][0]
        assert args == ["/mock/bin/aery-qgis-runner", "9999"]
        env = mock_popen.call_args.kwargs["env"]
        assert "AERY_CODING_AGENT_DIR" in env
        assert "--provider-file" not in args


def test_spawn_strips_conflicting_provider_env_vars_and_sets_agent_dir(bridge, tmp_path, monkeypatch):
    """spawn() removes OPENAI-style env vars and sets AERY_CODING_AGENT_DIR for isolation."""
    config_path = tmp_path / "provider_config.json"
    config_path.write_text(
        json.dumps({
            "baseUrl": "https://api.example.com/v1",
            "apiKey": "secret-key",
            "model": "geo-model",
            "authMode": "apikey",
        })
    )
    monkeypatch.setenv("OPENAI_API_KEY", "wrong-key")
    monkeypatch.setenv("OPENAI_BASE_URL", "https://wrong.example.com/v1")
    monkeypatch.setenv("ANTHROPIC_API_KEY", "wrong-anthropic")
    monkeypatch.setenv("GOOGLE_API_KEY", "wrong-google")

    with (
        patch("aery_plugin.rpc_bridge.CONFIG_PATH", str(config_path), create=True),
        patch("aery_plugin.rpc_bridge.os.path.exists", side_effect=lambda p: p == str(config_path)),
        patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen,
        patch("aery_plugin.rpc_bridge._find_aery_binary", return_value="/mock/bin/aery-qgis-runner"),
    ):
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = None
        mock_popen.return_value = mock_process

        bridge.spawn()

        env = mock_popen.call_args.kwargs["env"]
        assert "OPENAI_API_KEY" not in env
        assert "OPENAI_BASE_URL" not in env
        assert "ANTHROPIC_API_KEY" not in env
        assert "GOOGLE_API_KEY" not in env
        assert env["QGIS_EXECUTOR_PORT"] == "9999"
        # Agent dir isolation
        assert "AERY_CODING_AGENT_DIR" in env
        agent_dir = env["AERY_CODING_AGENT_DIR"]
        assert agent_dir.endswith("agent")
        assert os.path.isdir(agent_dir), f"Agent dir not created: {agent_dir}"
        # Verify settings.json was seeded with QGIS-only defaults
        settings_path = os.path.join(agent_dir, "settings.json")
        assert os.path.isfile(settings_path)
        with open(settings_path) as f:
            settings = json.load(f)
        assert settings["defaultProvider"] == "google-antigravity"
        assert settings["defaultModel"] == "gemini-3-flash"


def test_spawn_agent_dir_env_var_set(bridge):
    """spawn() sets AERY_CODING_AGENT_DIR in the child process env."""
    with (
        patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen,
        patch("aery_plugin.rpc_bridge._find_aery_binary", return_value="/mock/bin/aery-qgis-runner"),
    ):
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = None
        mock_popen.return_value = mock_process

        bridge.spawn()
        bridge._running = True  # keep alive for test assertions

        args = mock_popen.call_args[0][0]
        assert args == ["/mock/bin/aery-qgis-runner", "9999"]
        env = mock_popen.call_args.kwargs["env"]
        assert "AERY_CODING_AGENT_DIR" in env
        agent_dir = env["AERY_CODING_AGENT_DIR"]
        assert agent_dir.endswith("agent")


def test_spawn_file_not_found(bridge):
    """When aery is not found, error_occurred is emitted."""
    with patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen:
        mock_popen.side_effect = FileNotFoundError()

        errors = []
        bridge.error_occurred.connect(errors.append)

        bridge.spawn()
        assert len(errors) == 1
        assert "not found" in errors[0].lower()


def test_prompt_sends_command(bridge):
    """prompt() sends a prompt command via stdin."""
    with patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen:
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = None
        mock_popen.return_value = mock_process

        bridge.spawn()
        bridge.prompt("hello world")

        # Check what was written to stdin
        written = mock_process.stdin.write.call_args[0][0]
        data = json.loads(written.strip())
        assert data["type"] == "prompt"
        assert data["message"] == "hello world"


def test_follow_up_sends_command(bridge):
    """follow_up() sends a follow_up command."""
    with patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen:
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = None
        mock_popen.return_value = mock_process

        bridge.spawn()
        bridge.follow_up("queued message")

        written = mock_process.stdin.write.call_args[0][0]
        data = json.loads(written.strip())
        assert data["type"] == "follow_up"
        assert data["message"] == "queued message"


def test_abort_sends_all_three_commands(bridge):
    """abort() sends abort + abort_bash + abort_retry to fully stop the agent."""
    writes = []
    with patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen:
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.stdin.write = lambda s: writes.append(json.loads(s.strip()))
        mock_popen.return_value = mock_process

        bridge.spawn()
        bridge.abort()

    types = [w["type"] for w in writes]
    assert "abort" in types
    assert "abort_bash" in types
    assert "abort_retry" in types
    # Verify order: abort first, then bash/retry
    assert types[0] == "abort"
    assert types.count("abort") == 1


def test_dispatch_event_received(bridge):
    """_dispatch_event emits event_received for streaming events."""
    events = []
    bridge.event_received.connect(events.append)

    bridge._dispatch_event({"type": "message_start", "message": {"role": "assistant", "content": []}})
    assert len(events) == 1
    assert events[0]["type"] == "message_start"


def test_dispatch_response_received(bridge):
    """_dispatch_event emits response_received for response events."""
    responses = []
    bridge.response_received.connect(lambda cmd, data: responses.append((cmd, data)))

    bridge._dispatch_event({"type": "response", "command": "prompt", "success": True})
    assert len(responses) == 1
    cmd, data = responses[0]
    assert cmd == "prompt"
    assert data["type"] == "response"


def test_shutdown_terminates_process(bridge):
    """shutdown terminates the subprocess and cleans up."""
    with patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen:
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = None
        mock_popen.return_value = mock_process

        bridge.spawn()
        bridge.shutdown()

        mock_process.terminate.assert_called_once()


def test_shutdown_does_not_emit_process_exited(bridge):
    """Intentional shutdown should not send a crash/disconnect event to UI."""
    exits = []
    bridge.process_exited.connect(exits.append)

    with patch("aery_plugin.rpc_bridge.subprocess.Popen") as mock_popen:
        mock_process = MagicMock()
        mock_process.stdin = MagicMock()
        mock_process.stdout = MagicMock()
        mock_process.stderr = MagicMock()
        mock_process.stdout.readline.return_value = "\n"
        mock_process.poll.return_value = 0
        mock_popen.return_value = mock_process

        bridge.spawn()
        bridge.shutdown()
        bridge._read_stdout()

    assert exits == []


def test_dispatch_filters_thinking_events(bridge):
    """Thinking events are filtered out by _dispatch_event."""
    events = []
    bridge.event_received.connect(events.append)

    bridge._dispatch_event({"type": "thinking_start"})
    bridge._dispatch_event({"type": "thinking_delta", "delta": "test"})
    bridge._dispatch_event({"type": "thinking_end"})
    bridge._dispatch_event({"type": "message_start", "message": {"role": "assistant", "content": []}})

    assert len(events) == 1
    assert events[0]["type"] == "message_start"


def test_dispatch_strips_thinking_from_content(bridge):
    """Thinking blocks are stripped from message content."""
    events = []
    bridge.event_received.connect(events.append)

    bridge._dispatch_event({
        "type": "message_update",
        "message": {
            "role": "assistant",
            "content": [
                {"type": "thinking", "thinking": "I should think..."},
                {"type": "text", "text": "Actual response"},
            ],
        },
    })

    assert len(events) == 1
    content = events[0]["message"]["content"]
    assert len(content) == 1
    assert content[0]["type"] == "text"
